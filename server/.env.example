# RSS Reader server environment.
#
# Copy this file to `server/.env` and fill in the values:
#     cp server/.env.example server/.env
#
# `server/.env` is gitignored (never committed) and is rsynced to
# ~/Deploy/rss-reader/server/.env by deploy.sh, so set it once here.

# Basic auth for public access (https://rss.royl.uk:8443 via the rathole→Aliyun
# VPS + Caddy tunnel; see docs/rathole-vps-tunnel.md).
# When BOTH are set, EVERY /api/* request requires a valid session cookie — local
# and remote alike, no localhost bypass (log in via the web UI). Leave both empty
# to disable auth entirely (fully private use).
#
# Generate a strong password with:  openssl rand -base64 24
AUTH_USER=
AUTH_PASS=

# Server listen port (read by load-env.ts → config.ts). Defaults to 3002 when
# unset. The systemd unit / macOS plist no longer hardcode the port, so this is
# the single source of truth — change it here and restart the service.
PORT=3002
