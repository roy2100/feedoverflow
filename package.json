{
  "name": "rss-reader",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.ts",
    "client": "cd client && npm run dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  }
}
