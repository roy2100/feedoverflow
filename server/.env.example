# RSS Reader server environment.
#
# Copy this file to `server/.env` and fill in the values:
#     cp server/.env.example server/.env
#
# `server/.env` is gitignored (never committed) and is rsynced to
# ~/Deploy/rss-reader/server/.env by deploy.sh, so set it once here.

# Basic auth for public (Cloudflare Tunnel) access.
# When BOTH are set, non-localhost /api/* and /mcp requests require a valid
# session cookie (log in via the web UI). Leave both empty to disable auth
# entirely (localhost-only / fully private use).
#
# Generate a strong password with:  openssl rand -base64 24
AUTH_USER=
AUTH_PASS=
