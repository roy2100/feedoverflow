# `make build` names it rss-reader for the process title)
/server-go
/rss-reader
*.exe

# Coverage artifacts from `make cover`
coverage.out
coverage.html

# Local parity/test DB copies (never commit rss.db copies)
*.db
*.db-wal
*.db-shm
