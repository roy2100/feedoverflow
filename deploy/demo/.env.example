# Demo instance env (copied to ~/Deploy/rss-demo/server/.env by install-demo-service.sh).
#
# The demo is intentionally PUBLIC — do NOT set AUTH_USER / AUTH_PASS here, or the
# demo would demand a login it has no credentials for.

# Trim aggressively; the throwaway DB never needs to grow.
DB_MAX_SIZE_MB=256

# PORT / LOCAL_API_PORT / RSS_DB / CLIENT_DIST / LOG_DIR are injected by the
# launchd plist (see install-demo-service.sh), not here.

# rsshub_base_url lives in the DB `settings` table and is carried by the seed DB;
# set it there when building the seed (seed/README.md), not in this file.
