# @vitejs/plugin-react 6 declares an optional peer on @rolldown/plugin-babel
# (react-compiler / rolldown path we don't use), whose optional Babel-8 chain
# collides with the Babel 7 that vite-plugin-pwa -> workbox-build pins. A fresh
# `npm install` errors on that conflict, so accept the lockfile's resolution.
legacy-peer-deps=true
