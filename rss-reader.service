[Unit]
Description=RSS Reader Backend
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/rss-reader/server
ExecStart=/usr/bin/node index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=3002
# 设置这两个变量开启 basic auth，留空则不需要认证
Environment=AUTH_USER=admin
Environment=AUTH_PASS=changeme

# Keep stdout/stderr in journald
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rss-reader

[Install]
WantedBy=multi-user.target
